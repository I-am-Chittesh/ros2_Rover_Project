<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_rover">

    <!-- ========================================================== -->
    <!-- INERTIA MACROS (Baked in so you don't need extra files)    -->
    <!-- ========================================================== -->
    <xacro:macro name="box_inertia" params="m w h d">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
                     iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
                     izz="${(m/12) * (w*w + h*h)}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0"
                     iyy="${(m/12) * (3*r*r + h*h)}" iyz="0"
                     izz="${(m/2) * (r*r)}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="sphere_inertia" params="m r">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0"
                     iyy="${(2/5) * m * (r*r)}" iyz="0.0"
                     izz="${(2/5) * m * (r*r)}"/>
        </inertial>
    </xacro:macro>


    <!-- ========================================================== -->
    <!-- ROBOT GEOMETRY & JOINTS                                    -->
    <!-- ========================================================== -->

    <!-- BASE LINK (Chassis) -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/chasis.STL" scale="1 1 1"/>
            </geometry>
            <material name="red">
                <color rgba="0.8 0.1 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.12 0.11 0.05"/> 
            </geometry>
        </collision>
        <xacro:box_inertia m="1.2" w="0.12" h="0.11" d="0.05"/>
    </link>

    <!-- LEFT WHEEL -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.03 0.065 -0.02" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/wheel_link.STL" scale="1 1 1"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.025"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.25" r="0.03" h="0.025"/>
    </link>

    <!-- RIGHT WHEEL -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.03 -0.065 -0.02" rpy="1.5708 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/wheel_link.STL" scale="1 1 1"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.025"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.25" r="0.03" h="0.025"/>
    </link>

    <!-- CASTOR BALL -->
    <joint name="castor_joint" type="fixed">
        <parent link="base_link"/>
        <child link="castor_link"/>
        <origin xyz="-0.04 0 -0.03" rpy="0 0 0"/>
    </joint>

    <link name="castor_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/castor_ball.STL" scale="1 1 1"/>
            </geometry>
            <material name="silver">
                <color rgba="0.75 0.75 0.75 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/> 
            </geometry>
        </collision>
        <xacro:sphere_inertia m="0.1" r="0.015"/>
    </link>

    <!-- LIDAR LINK -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <link name="lidar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/laser_link.STL" scale="1 1 1"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.035"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.15" r="0.03" h="0.035"/>
    </link>

    <!-- GAZEBO COLOR FIXES -->
    <gazebo reference="base_link"><material>Gazebo/Red</material></gazebo>
    <gazebo reference="left_wheel"><material>Gazebo/Black</material></gazebo>
    <gazebo reference="right_wheel"><material>Gazebo/Black</material></gazebo>
    <gazebo reference="castor_link"><material>Gazebo/Silver</material></gazebo>
    <gazebo reference="lidar_link"><material>Gazebo/DarkGrey</material></gazebo>

</robot>