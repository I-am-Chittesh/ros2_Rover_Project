<?xml version="1.0" ?>
<robot name="final_assemble_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find final_assemble_rover_description)/urdf/materials.xacro" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/final_assemble_rover.trans" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/final_assemble_rover.gazebo" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/gazebo_control.xacro" />  

    <!-- ROOT LINK -->
    <link name="base_footprint"/>
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/> 
    </joint>

    <!-- CHASSIS -->
    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <!-- 90 degree pitch maps Fusion Z-up to ROS standard -->
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><mesh filename="file://$(find final_assemble_rover_description)/meshes/base_link.stl" /></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.2 0.15 0.08"/></geometry>
        </collision>
    </link>

    <!-- RIGHT WHEEL -->
    <link name="right_wheel_link_1_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />  
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><mesh filename="file://$(find final_assemble_rover_description)/meshes/right_wheel_link_1.stl" /></geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder radius="0.04" length="0.02"/></geometry>
        </collision>
    </link>
    <joint name="Revolute 19" type="continuous">
        <origin xyz="-0.05 -0.09 -0.04" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link_1_1"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- LEFT WHEEL -->
    <link name="left_wheel_link_1_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />  
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><mesh filename="file://$(find final_assemble_rover_description)/meshes/left_wheel_link_1.stl" /></geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder radius="0.04" length="0.02"/></geometry>
        </collision>
    </link>
    <joint name="Revolute 20" type="continuous">
        <origin xyz="-0.05 0.09 -0.04" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link_1_1"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- CASTOR WHEEL -->
    <link name="castor_link_1_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.01"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />  
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><mesh filename="file://$(find final_assemble_rover_description)/meshes/castor_link_1.stl"/></geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><sphere radius="0.02"/></geometry>
        </collision>
    </link>
    <joint name="Rigid 21" type="fixed">
        <origin xyz="0.08 0 -0.06" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="castor_link_1_1"/>
    </joint>

    <!-- LASER SENSOR -->
    <link name="laser_link_1_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.01"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />  
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><mesh filename="file://$(find final_assemble_rover_description)/meshes/laser_link_1.stl"/></geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.03 0.03 0.03"/></geometry>
        </collision>
    </link>
    <joint name="Rigid 22" type="fixed">
        <origin xyz="0.05 0 0.05" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="laser_link_1_1"/>
    </joint>

</robot>