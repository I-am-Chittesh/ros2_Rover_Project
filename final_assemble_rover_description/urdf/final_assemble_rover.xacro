<?xml version="1.0" ?>
<robot name="final_assemble_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- The Root Link -->
    <link name="base_footprint"/>

    <!-- The Joint connecting the Root to the Chassis -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.1" rpy="1.5708 0 0"/> 
    </joint>

    <xacro:include filename="$(find final_assemble_rover_description)/urdf/materials.xacro" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/final_assemble_rover.trans" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/final_assemble_rover.gazebo" />
    <xacro:include filename="$(find final_assemble_rover_description)/urdf/gazebo_control.xacro" />  


    <link name="base_link">
        <inertial>
            <origin xyz="-0.012288395840692032 0.034460399576695354 0.0011969906215803167" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/base_link.stl" />
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/base_link.stl" />
            </geometry>
        </collision>
    </link>

    <link name="right_wheel_link_1_1">
        <inertial>
            <origin xyz="2.6630935998084304e-08 -2.8968758173167353e-07 0.009889971933162212" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <origin xyz="0.029 -0.025 -0.06121" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/right_wheel_link_1_1.stl" />
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.029 -0.025 -0.06121" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/right_wheel_link_1_1.stl" />
            </geometry>
        </collision>
    </link>

    <link name="left_wheel_link_1_1">
        <inertial>
            <origin xyz="-2.661230842117279e-07 7.953542884714393e-08 -0.009889974242528299" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <origin xyz="0.029 -0.025 0.06121" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/left_wheel_link_1_1.stl" />
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.029 -0.025 0.06121" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/left_wheel_link_1_1.stl" />
            </geometry>
        </collision>
    </link>

    <link name="castor_link_1_1">
        <inertial>
            <origin xyz="4.5208840455945865e-07 -1.0408340855860843e-17 -6.181836115575344e-17" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <origin xyz="-0.039746 0.0076 0.0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/castor_link_1_1.stl"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="-0.039746 0.0076 0.0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/castor_link_1_1.stl"/>
            </geometry>
        </collision>
    </link>

    <link name="laser_link_1_1">
        <inertial>
            <origin xyz="0.003060220670157498 0.024734911622924308 0.0005321423848153578" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />  
        </inertial>
        <visual>
            <origin xyz="0.0025 -0.09965 -0.0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/laser_link_1_1.stl"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.0025 -0.09965 -0.0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find final_assemble_rover_description)/meshes/laser_link_1_1.stl"/>
            </geometry>
        </collision>
    </link>

    <joint name="Revolute 19" type="continuous">
        <origin xyz="-0.029 0.025 0.06121" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link_1_1"/>
        <axis xyz="0.0 0.0 -1.0"/>
    </joint>

    <joint name="Revolute 20" type="continuous">
        <origin xyz="-0.029 0.025 -0.06121" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link_1_1"/>
        <axis xyz="0.0 0.0 -1.0"/>
    </joint>

    <joint name="Rigid 21" type="fixed">
        <origin xyz="0.039746 -0.0076 0.0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="castor_link_1_1"/>
    </joint>

    <joint name="Rigid 22" type="fixed">
        <origin xyz="-0.0025 0.09965 0.0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="laser_link_1_1"/>
    </joint>

</robot>